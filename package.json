{
	"name": "compress-pro",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"description": "Free, open-source, ad-free, private-by-design file compressor — JPG, PNG, WebP, GIF, HEIC, SVG, PDF, video and audio — plus format converters, PDF tools (merge, split, unlock, protect), image resizing, ZIP, and lossless EXIF removal. Runs entirely in the browser via WebAssembly + WebCodecs.",
	"author": {
		"name": "Nik Klemenc",
		"url": "https://klemenc.si"
	},
	"homepage": "https://compress-pro.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/Scorpio3310/compress-pro"
	},
	"license": "MIT",
	"keywords": [
		"image-compression",
		"pdf-compression",
		"video-compression",
		"audio-compression",
		"webp",
		"avif",
		"heic",
		"webassembly",
		"webcodecs",
		"remove-exif",
		"privacy",
		"client-side",
		"svelte",
		"sveltekit",
		"cloudflare"
	],
	"packageManager": "pnpm@10.26.2",
	"engines": {
		"node": ">=22.12"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "pnpm build && wrangler dev",
		"deploy": "pnpm build && wrangler deploy",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"check:e2e": "tsc -p e2e/tsconfig.json --noEmit",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"fixtures": "node scripts/generate-fixtures.mjs",
		"og": "node scripts/generate-og.mjs",
		"icons": "node scripts/generate-icons.mjs",
		"test:e2e": "playwright test",
		"test:e2e:smoke": "playwright test --grep @smoke",
		"test:e2e:quick": "E2E_QUICK=1 playwright test --grep-invert @slow",
		"test:e2e:xbrowser": "E2E_XBROWSER=1 playwright test --grep @xbrowser",
		"test:e2e:preview": "E2E_PREVIEW=1 playwright test",
		"test:e2e:ui": "playwright test --ui",
		"report": "node scripts/build-report.mjs --open"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^5.20260708.1",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/geist-mono": "^5.2.8",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.69.2",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.2",
		"@types/emscripten": "^1.41.5",
		"@types/node": "^26.1.1",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"pixelmatch": "^7.2.0",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"sharp": "^0.35.3",
		"ssim.js": "^3.5.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.2",
		"tailwindcss": "^4.3.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.63.0",
		"vite": "^8.1.4",
		"vitest": "^4.1.10",
		"wrangler": "^4.110.0"
	},
	"dependencies": {
		"@fontsource-variable/plus-jakarta-sans": "^5.2.8",
		"@jsquash/avif": "^2.1.1",
		"@jsquash/jpeg": "^1.6.0",
		"@jsquash/oxipng": "^2.3.0",
		"@jsquash/png": "^3.1.1",
		"@jsquash/resize": "^2.1.1",
		"@jsquash/webp": "^1.5.0",
		"@mediabunny/mp3-encoder": "1.50.8",
		"@okathira/ghostpdl-wasm": "^1.1.0",
		"fflate": "^0.8.3",
		"gifenc": "^1.0.3",
		"gifsicle-wasm-browser": "^1.5.19",
		"icodec": "^0.6.0",
		"mediabunny": "1.50.8",
		"motion": "^12.42.2",
		"pdf-lib": "1.17.1",
		"pdfjs-dist": "^6.1.200",
		"svgo": "^4.0.1",
		"utif2": "4.1.0"
	}
}
